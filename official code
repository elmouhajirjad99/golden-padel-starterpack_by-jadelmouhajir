<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Golden Padel Club — Tanger</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --gold:#C9A84C;--gold-light:#F0D080;--gold-dark:#8B6914;
    --navy:#0D1B2A;--navy2:#132336;--navy3:#1A2F45;--navy4:#213852;
    --black:#070E15;--white:#FAFAF5;--gray:#8899AA;--gray-light:#BDC9D5;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{font-family:'DM Sans',sans-serif;background:var(--black);color:var(--white);overflow-x:hidden;}
  h1,h2,h3,h4{font-family:'Playfair Display',serif;}
  nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:1.1rem 4rem;background:rgba(7,14,21,0.97);backdrop-filter:blur(8px);border-bottom:1px solid rgba(201,168,76,0.15);}
  .logo{display:flex;align-items:center;gap:12px;text-decoration:none;}
  .logo-img{width:52px;height:52px;flex-shrink:0;border-radius:8px;object-fit:cover;display:block;}
  .logo-text-block .logo-name{font-family:'Playfair Display',serif;font-size:1.18rem;font-weight:700;color:var(--gold);letter-spacing:1px;line-height:1.1;}
  .logo-text-block .logo-sub{font-size:0.58rem;color:var(--gray-light);letter-spacing:3px;text-transform:uppercase;}
  nav ul{list-style:none;display:flex;gap:1.8rem;align-items:center;}
  nav ul a{color:var(--white);text-decoration:none;font-size:0.8rem;letter-spacing:1px;text-transform:uppercase;font-weight:500;opacity:0.8;transition:opacity .2s,color .2s;}
  nav ul a:hover{opacity:1;color:var(--gold);}
  .nav-cta{background:var(--gold)!important;color:var(--black)!important;padding:.5rem 1.2rem!important;border-radius:2px;font-weight:700!important;opacity:1!important;}
  .nav-cta:hover{background:var(--gold-light)!important;}
  .nav-dropdown{position:relative;}
  .nav-dropdown>a{display:flex;align-items:center;gap:4px;}
  .nav-dropdown>a::after{content:'▾';font-size:.68rem;}
  .dropdown-menu{display:none;position:absolute;top:calc(100% + 10px);left:0;background:var(--navy2);border:1px solid rgba(201,168,76,.2);border-radius:4px;min-width:175px;overflow:hidden;box-shadow:0 10px 30px rgba(0,0,0,.5);}
  .nav-dropdown:hover .dropdown-menu{display:block;}
  .dropdown-menu a{display:block;padding:.65rem 1.1rem;color:var(--gray-light)!important;font-size:.8rem!important;opacity:1!important;border-bottom:1px solid rgba(255,255,255,.05);transition:background .2s!important;}
  .dropdown-menu a:hover{background:rgba(201,168,76,.1);color:var(--gold)!important;}
  .promo-banner{background:linear-gradient(90deg,var(--gold-dark),var(--gold),var(--gold-dark));padding:.85rem 4rem;display:flex;align-items:center;justify-content:center;gap:2rem;flex-wrap:wrap;}
  .promo-banner p{color:var(--black);font-weight:600;font-size:.9rem;}
  .promo-btn{background:var(--black);color:var(--gold);padding:.5rem 1.3rem;border-radius:2px;font-weight:700;font-size:.78rem;text-decoration:none;white-space:nowrap;}
  .hero{min-height:100vh;position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden;padding-top:80px;}
  .hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 70% 50%,rgba(201,168,76,.08) 0%,transparent 60%),linear-gradient(135deg,var(--black) 0%,var(--navy) 50%,#061220 100%);}
  .court-lines{position:absolute;inset:0;opacity:.035;background-image:linear-gradient(var(--gold) 1px,transparent 1px),linear-gradient(90deg,var(--gold) 1px,transparent 1px);background-size:60px 60px;}
  .hero-content{position:relative;z-index:2;text-align:center;padding:0 2rem;animation:fadeUp 1s ease both;}
  .hero-badge{display:inline-block;border:1px solid var(--gold);color:var(--gold);padding:.4rem 1.4rem;font-size:.68rem;letter-spacing:4px;text-transform:uppercase;margin-bottom:2rem;border-radius:1px;}
  .hero-title-row{display:flex;align-items:center;justify-content:center;gap:1.5rem;flex-wrap:wrap;}
  .hero h1{font-size:clamp(3.5rem,8vw,7rem);font-weight:900;line-height:1;margin-bottom:.3rem;}
  .hero h1 span{color:var(--gold);}
  .hero-logo-big{width:clamp(80px,9vw,130px);height:clamp(80px,9vw,130px);flex-shrink:0;border-radius:12px;object-fit:cover;display:block;}
  .hero-sub{font-size:1rem;color:var(--gray-light);letter-spacing:6px;text-transform:uppercase;margin-bottom:2.5rem;font-weight:300;}
  .hero p{max-width:580px;margin:0 auto 3rem;font-size:1.05rem;color:var(--gray);line-height:1.85;}
  .hero-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;}
  .btn-gold{background:var(--gold);color:var(--black);padding:.9rem 2.3rem;font-weight:700;font-size:.88rem;letter-spacing:1px;text-transform:uppercase;border:none;cursor:pointer;border-radius:2px;text-decoration:none;display:inline-block;transition:background .2s,transform .2s;font-family:'DM Sans',sans-serif;}
  .btn-gold:hover{background:var(--gold-light);transform:translateY(-2px);}
  .btn-outline{background:transparent;color:var(--white);padding:.9rem 2.3rem;font-weight:500;font-size:.88rem;letter-spacing:1px;text-transform:uppercase;border:1px solid rgba(255,255,255,.3);cursor:pointer;border-radius:2px;text-decoration:none;display:inline-block;transition:border-color .2s,color .2s;font-family:'DM Sans',sans-serif;}
  .btn-outline:hover{border-color:var(--gold);color:var(--gold);}
  .hero-scroll{position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;color:var(--gray);font-size:.72rem;letter-spacing:2px;text-transform:uppercase;animation:bounce 2s infinite;}
  .scroll-line{width:1px;height:50px;background:linear-gradient(var(--gold),transparent);}
  .stats-banner{background:var(--gold);padding:2rem 4rem;display:grid;grid-template-columns:repeat(4,1fr);gap:2rem;text-align:center;}
  .stat-num{font-family:'Playfair Display',serif;font-size:2.5rem;font-weight:900;color:var(--black);line-height:1;}
  .stat-label{font-size:.7rem;font-weight:600;color:var(--black);opacity:.65;letter-spacing:2px;text-transform:uppercase;margin-top:4px;}
  section{padding:6rem 4rem;}
  .section-label{color:var(--gold);font-size:.68rem;letter-spacing:4px;text-transform:uppercase;margin-bottom:1rem;font-weight:600;}
  .section-title{font-size:clamp(2rem,4vw,3.2rem);font-weight:700;margin-bottom:1.2rem;line-height:1.15;}
  .section-desc{color:var(--gray);font-size:1.02rem;line-height:1.85;max-width:620px;}
  .divider{width:60px;height:2px;background:var(--gold);margin:1.5rem 0;}
  .terrains-section{background:var(--navy);}
  .terrains-layout{display:grid;grid-template-columns:1fr 1fr;gap:4rem;margin-top:3.5rem;align-items:start;}
  .panorama-wrap{position:relative;border-radius:6px;overflow:hidden;border:1px solid rgba(201,168,76,.25);background:var(--navy2);}
  .panorama-photo{width:100%;display:block;object-fit:cover;min-height:300px;}
  .panorama-overlay{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;}
  .court-zone{fill:rgba(0,0,0,0);cursor:pointer;transition:fill .35s,filter .35s;pointer-events:all;}
  .court-zone:hover{fill:rgba(201,168,76,0.18);}
  .court-zone.selected{fill:rgba(200,30,30,0.45)!important;filter:drop-shadow(0 0 8px rgba(220,40,40,0.6));}
  .terrain-badge-overlay{position:absolute;top:8px;left:50%;transform:translateX(-50%);background:rgba(7,14,21,.85);color:var(--gold);font-size:.72rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;padding:5px 14px;border-radius:2px;backdrop-filter:blur(4px);white-space:nowrap;pointer-events:none;}
  .terrain-grid-box{background:var(--navy2);border:1px solid rgba(201,168,76,.15);border-radius:4px;padding:1.5rem;}
  .terrain-grid-box h3{font-size:1.1rem;margin-bottom:.4rem;}
  .terrain-grid-box p{color:var(--gray);font-size:.83rem;margin-bottom:1.2rem;}
  .terrain-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:1.2rem;}
  .terrain-btn{aspect-ratio:1;border-radius:4px;border:2px solid rgba(201,168,76,.2);background:var(--navy3);color:var(--gray-light);font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:700;cursor:pointer;transition:all .25s;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:3px;}
  .terrain-btn:hover{border-color:var(--gold);color:var(--gold);background:rgba(201,168,76,.05);}
  .terrain-btn.selected{border-color:#cc3333;background:rgba(178,34,34,.18);color:#ff7777;box-shadow:0 0 0 2px rgba(178,34,34,.2);}
  .terrain-btn.not-visible{opacity:0.45;cursor:not-allowed;border-style:dashed;}
  .terrain-btn span{font-size:.58rem;color:var(--gray);font-family:'DM Sans',sans-serif;font-weight:500;letter-spacing:1px;text-transform:uppercase;}
  .terrain-info-box{background:rgba(201,168,76,.07);border:1px solid rgba(201,168,76,.2);border-radius:4px;padding:1rem 1.2rem;font-size:.86rem;color:var(--gray-light);min-height:72px;display:flex;align-items:center;}
  .tarifs{background:var(--black);}
  .tarifs-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem;margin-top:3.5rem;max-width:860px;}
  .tarif-card{background:var(--navy2);border:1px solid rgba(201,168,76,.15);border-radius:4px;padding:2.5rem 2rem;text-align:center;transition:border-color .3s,transform .3s;position:relative;overflow:hidden;}
  .tarif-card.featured{border-color:var(--gold);background:linear-gradient(160deg,rgba(201,168,76,.08) 0%,var(--navy2) 100%);}
  .tarif-card:hover{border-color:var(--gold);transform:translateY(-4px);}
  .popular-badge{position:absolute;top:0;left:50%;transform:translateX(-50%);background:var(--gold);color:var(--black);font-size:.6rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;padding:5px 18px;border-radius:0 0 4px 4px;}
  .tarif-icon{font-size:2rem;margin-bottom:.8rem;margin-top:.5rem;}
  .tarif-name{font-family:'Playfair Display',serif;font-size:1.4rem;margin-bottom:.5rem;}
  .tarif-price{font-family:'Playfair Display',serif;font-size:2.6rem;font-weight:900;color:var(--gold);line-height:1;}
  .tarif-period{color:var(--gray);font-size:.8rem;margin-bottom:1.5rem;}
  .tarif-features{list-style:none;text-align:left;margin-bottom:1.5rem;}
  .tarif-features li{padding:.48rem 0;border-bottom:1px solid rgba(255,255,255,.06);font-size:.86rem;color:var(--gray-light);display:flex;align-items:flex-start;gap:9px;}
  .tarif-features li::before{content:'✓';color:var(--gold);font-weight:700;font-size:.78rem;flex-shrink:0;margin-top:2px;}
  .tarif-note{font-size:.75rem;color:var(--gray);margin-bottom:1rem;font-style:italic;}
  .amenities{background:var(--navy);}
  .amenities-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.2rem;margin-top:3.5rem;}
  .amenity-card{background:var(--navy2);border:1px solid rgba(201,168,76,.1);border-radius:4px;padding:1.7rem 1.3rem;text-align:center;transition:border-color .3s;}
  .amenity-card:hover{border-color:var(--gold);}
  .amenity-icon{width:50px;height:50px;background:rgba(201,168,76,.1);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.35rem;}
  .amenity-name{font-family:'Playfair Display',serif;font-size:1rem;margin-bottom:.4rem;}
  .amenity-desc{color:var(--gray);font-size:.8rem;line-height:1.6;}
  .reservation{background:linear-gradient(135deg,var(--navy) 0%,#061220 100%);position:relative;overflow:hidden;}
  .reservation::before{content:'';position:absolute;right:-200px;top:-200px;width:600px;height:600px;background:radial-gradient(circle,rgba(201,168,76,.06) 0%,transparent 60%);}
  .reservation-inner{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:start;}
  .booking-form{background:var(--navy2);border:1px solid rgba(201,168,76,.2);border-radius:4px;padding:2.3rem;}
  .booking-form h3{font-size:1.4rem;margin-bottom:.4rem;}
  .booking-form>.sub{color:var(--gray);font-size:.83rem;margin-bottom:1.4rem;}
  .form-group{margin-bottom:1rem;}
  .form-group label{display:block;font-size:.75rem;color:var(--gray);letter-spacing:1px;text-transform:uppercase;margin-bottom:.4rem;}
  .form-group input,.form-group select{width:100%;background:var(--navy3);border:1px solid rgba(255,255,255,.1);color:var(--white);padding:.72rem .95rem;border-radius:2px;font-family:'DM Sans',sans-serif;font-size:.92rem;outline:none;transition:border-color .2s;}
  .form-group input:focus,.form-group select:focus{border-color:var(--gold);}
  .form-group select option{background:var(--navy2);}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
  .form-error{font-size:.75rem;color:#FF6B6B;margin-top:4px;display:none;}
  .form-error.show{display:block;}
  .hour-unavail{font-size:.78rem;color:#FF8C42;margin-top:5px;display:none;background:rgba(255,140,66,.08);border:1px solid rgba(255,140,66,.25);border-radius:3px;padding:6px 10px;}
  .hour-unavail.show{display:block;}
  .price-preview{background:rgba(201,168,76,.08);border:1px solid rgba(201,168,76,.2);border-radius:4px;padding:.9rem 1.1rem;margin-bottom:.9rem;display:flex;justify-content:space-between;align-items:center;}
  .price-preview span{color:var(--gray);font-size:.83rem;}
  .price-preview strong{color:var(--gold);font-size:1.2rem;font-family:'Playfair Display',serif;}
  .horaires-table{width:100%;border-collapse:collapse;margin-top:1.5rem;}
  .horaires-table tr{border-bottom:1px solid rgba(255,255,255,.06);}
  .horaires-table td{padding:.7rem 0;font-size:.86rem;}
  .horaires-table td:first-child{color:var(--gray);}
  .horaires-table td:last-child{color:var(--gold);font-weight:600;text-align:right;}
  .open-badge{display:inline-block;background:rgba(27,77,46,.4);color:#5CCC85;font-size:.62rem;font-weight:700;padding:3px 8px;border-radius:20px;letter-spacing:1px;text-transform:uppercase;margin-left:6px;}
  .duration-info-box{background:rgba(201,168,76,.06);border:1px solid rgba(201,168,76,.18);border-radius:4px;padding:.8rem 1rem;margin-top:1.5rem;margin-bottom:.5rem;font-size:.86rem;color:var(--gray-light);}
  .dispo-section{background:var(--black);}
  .dispo-inner{display:grid;grid-template-columns:1fr 1fr;gap:3rem;margin-top:2.5rem;align-items:start;}
  .chat-box{background:var(--navy2);border:1px solid rgba(201,168,76,.2);border-radius:8px;overflow:hidden;display:flex;flex-direction:column;height:540px;}
  .chat-header{background:var(--navy3);border-bottom:1px solid rgba(201,168,76,.15);padding:.9rem 1.4rem;display:flex;align-items:center;gap:12px;}
  .chat-avatar-img{width:34px;height:34px;border-radius:50%;object-fit:cover;flex-shrink:0;}
  .chat-name{font-weight:600;font-size:.92rem;}
  .chat-status{font-size:.72rem;color:#5CCC85;display:flex;align-items:center;gap:4px;}
  .chat-status::before{content:'';width:6px;height:6px;background:#5CCC85;border-radius:50%;display:inline-block;}
  .chat-msgs{flex:1;overflow-y:auto;padding:1.1rem;display:flex;flex-direction:column;gap:.75rem;scrollbar-width:thin;scrollbar-color:rgba(201,168,76,.2) transparent;}
  .chat-msgs::-webkit-scrollbar{width:4px;}
  .chat-msgs::-webkit-scrollbar-thumb{background:rgba(201,168,76,.2);border-radius:2px;}
  .msg{max-width:90%;display:flex;flex-direction:column;gap:3px;}
  .msg.admin{align-self:flex-start;}
  .msg.user{align-self:flex-end;}
  .msg-lbl{font-size:.65rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;}
  .msg.admin .msg-lbl{color:var(--gold);}
  .msg.user .msg-lbl{color:var(--gray);text-align:right;}
  .msg-bubble{padding:.65rem .95rem;border-radius:8px;font-size:.86rem;line-height:1.5;}
  .msg.admin .msg-bubble{background:var(--navy3);border:1px solid rgba(201,168,76,.12);border-radius:2px 10px 10px 10px;}
  .msg.user .msg-bubble{background:rgba(201,168,76,.14);border:1px solid rgba(201,168,76,.22);border-radius:10px 2px 10px 10px;}
  .msg-time{font-size:.63rem;color:var(--gray);}
  .msg.user .msg-time{text-align:right;}
  .msg.slot-msg{align-self:flex-start;max-width:94%;}
  .slot-bubble{background:var(--navy3);border:1px solid rgba(201,168,76,.25);border-radius:2px 10px 10px 10px;padding:.75rem 1rem;cursor:pointer;transition:border-color .2s,background .2s;}
  .slot-bubble:hover{border-color:var(--gold);background:rgba(201,168,76,.06);}
  .slot-bubble.expanded{border-color:var(--gold);}
  .slot-bubble-header{display:flex;align-items:center;gap:8px;margin-bottom:4px;}
  .slot-dot{width:8px;height:8px;background:#5CCC85;border-radius:50%;flex-shrink:0;animation:pulse-green 1.5s infinite;}
  @keyframes pulse-green{0%,100%{box-shadow:0 0 0 0 rgba(92,204,133,.5);}50%{box-shadow:0 0 0 5px rgba(92,204,133,0);}}
  .slot-bubble-title{font-size:.8rem;font-weight:700;color:var(--gold);letter-spacing:1px;text-transform:uppercase;}
  .slot-bubble-detail{font-size:.88rem;color:var(--gray-light);line-height:1.5;}
  .slot-hint{font-size:.72rem;color:var(--gray);margin-top:5px;font-style:italic;}
  .slot-actions{display:none;flex-direction:column;gap:.5rem;margin-top:.8rem;padding-top:.8rem;border-top:1px solid rgba(201,168,76,.15);}
  .slot-actions.show{display:flex;}
  .slot-btn{width:100%;padding:.62rem 1rem;border-radius:3px;font-size:.82rem;font-weight:700;cursor:pointer;border:none;font-family:'DM Sans',sans-serif;letter-spacing:.5px;text-transform:uppercase;transition:background .2s,transform .15s;}
  .slot-btn:hover{transform:translateY(-1px);}
  .slot-btn.confirm{background:var(--gold);color:var(--black);}
  .slot-btn.confirm:hover{background:var(--gold-light);}
  .slot-btn.decline{background:rgba(255,100,100,.12);color:#ff8888;border:1px solid rgba(255,100,100,.2);}
  .slot-btn.decline:hover{background:rgba(255,100,100,.2);}
  .slot-declined-tag{display:inline-block;background:rgba(255,100,100,.12);color:#ff8888;font-size:.68rem;font-weight:700;padding:3px 9px;border-radius:10px;margin-top:6px;letter-spacing:1px;}
  .chat-input-area{border-top:1px solid rgba(201,168,76,.1);padding:.9rem 1.1rem;display:flex;gap:.7rem;align-items:center;}
  .chat-input-area input{flex:1;background:var(--navy3);border:1px solid rgba(255,255,255,.1);color:var(--white);padding:.6rem .95rem;border-radius:20px;font-family:'DM Sans',sans-serif;font-size:.88rem;outline:none;transition:border-color .2s;}
  .chat-input-area input:focus{border-color:var(--gold);}
  .chat-send{width:36px;height:36px;background:var(--gold);border:none;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0;transition:background .2s;}
  .chat-send:hover{background:var(--gold-light);}
  .info-card{background:var(--navy2);border:1px solid rgba(201,168,76,.15);border-radius:6px;padding:1.4rem;margin-bottom:1.1rem;}
  .info-card h4{color:var(--gold);font-size:.78rem;letter-spacing:2px;text-transform:uppercase;margin-bottom:1rem;font-family:'DM Sans',sans-serif;font-weight:600;}
  .dispo-slot{display:flex;align-items:center;justify-content:space-between;padding:.55rem 0;border-bottom:1px solid rgba(255,255,255,.05);}
  .dispo-slot:last-child{border-bottom:none;}
  .slot-time{font-size:.88rem;font-weight:500;}
  .slot-terrain-lbl{font-size:.78rem;color:var(--gray);}
  .step-row{display:flex;gap:10px;align-items:flex-start;margin-bottom:.75rem;}
  .step-num{background:var(--gold);color:var(--black);width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.68rem;font-weight:700;flex-shrink:0;}
  .nouveautes{background:var(--navy);}
  .news-grid{display:grid;grid-template-columns:2fr 1fr;gap:1.5rem;margin-top:3.5rem;}
  .news-card{background:var(--navy2);border:1px solid rgba(201,168,76,.15);border-radius:4px;overflow:hidden;transition:border-color .3s,transform .3s;cursor:pointer;}
  .news-card:hover{border-color:var(--gold);transform:translateY(-3px);}
  .news-content{padding:1.4rem;}
  .news-tag{display:inline-block;background:rgba(201,168,76,.12);color:var(--gold);font-size:.6rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;padding:4px 9px;border-radius:1px;margin-bottom:.75rem;}
  .news-title{font-family:'Playfair Display',serif;font-size:1.2rem;margin-bottom:.45rem;line-height:1.3;}
  .news-excerpt{color:var(--gray);font-size:.85rem;line-height:1.7;margin-bottom:.75rem;}
  .news-date{color:var(--gray);font-size:.74rem;}
  .side-news{display:flex;flex-direction:column;gap:1rem;}
  .news-small{background:var(--navy2);border:1px solid rgba(201,168,76,.1);border-radius:4px;overflow:hidden;transition:border-color .3s;cursor:pointer;}
  .news-small:hover{border-color:var(--gold);}
  .news-small-body{padding:.85rem;}
