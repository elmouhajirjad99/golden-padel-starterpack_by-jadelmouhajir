<script>
const bookedSlots={"2":["16:00","17:00"],"5":["20:00","21:00"]};
const terrainData=[
  {num:1,surface:"Gazon synthétique",lumens:"LED 1000 lux",dispo:"Disponible",visible:false},
  {num:2,surface:"Gazon synthétique",lumens:"LED 1000 lux",dispo:"Réservé 16h–18h",visible:true},
  {num:3,surface:"Gazon synthétique",lumens:"LED 1000 lux",dispo:"Disponible",visible:true},
  {num:4,surface:"Gazon synthétique",lumens:"LED 800 lux",dispo:"Disponible",visible:true},
  {num:5,surface:"Gazon synthétique",lumens:"LED 1000 lux",dispo:"Réservé 20h–22h",visible:false},
];
let selectedTerrain=null;
function selectTerrain(num){
  [2,3,4].forEach(n=>{const z=document.getElementById('zone'+n);if(z)z.classList.remove('selected');});
  document.querySelectorAll('.terrain-btn').forEach(b=>b.classList.remove('selected'));
  if(selectedTerrain===num){
    selectedTerrain=null;
    document.getElementById('panoramaLabel').textContent='Cliquez sur un terrain pour le localiser';
    document.getElementById('terrainInfoBox').innerHTML='<span style="color:var(--gray)">👆 Cliquez sur un terrain pour voir ses informations</span>';
    return;
  }
  selectedTerrain=num;
  const t=terrainData[num-1];
  const z=document.getElementById('zone'+num);
  if(z)z.classList.add('selected');
  document.getElementById('panoramaLabel').textContent=t.visible?'Terrain '+num+' — localisé sur la photo ✓':'Terrain '+num+' — non visible sur cette vue';
  const btn=document.querySelector('.terrain-btn[data-num="'+num+'"]');
  if(btn)btn.classList.add('selected');
  const ok=t.dispo==='Disponible';
  const visTag=t.visible?'<span style="color:#5CCC85;font-size:.78rem;">👁 Visible sur la photo</span>':'<span style="color:var(--gray);font-size:.78rem;">👁 Non visible sur cette vue</span>';
  document.getElementById('terrainInfoBox').innerHTML=`<div><p><strong style="color:var(--gold)">Terrain ${t.num}</strong> &nbsp;${visTag}</p><p style="margin-top:6px;font-size:.83rem;color:var(--gray-light)">Surface : ${t.surface}</p><p style="font-size:.83rem;color:var(--gray-light)">Éclairage : ${t.lumens}</p><p style="margin-top:8px;font-size:.86rem">Statut : <strong style="color:${ok?'#5CCC85':'#FF9966'}">${t.dispo}</strong></p></div>`;
}
const grid=document.getElementById('terrainGrid');
terrainData.forEach(t=>{
  const btn=document.createElement('button');
  btn.className='terrain-btn'+(t.visible?'':' not-visible');
  btn.setAttribute('data-num',t.num);
  btn.innerHTML=`${t.num}<span>${t.visible?'Visible':'Terrain'}</span>`;
  btn.title=t.visible?'Terrain '+t.num+' — visible sur la photo':'Terrain '+t.num+' — non visible';
  btn.onclick=()=>selectTerrain(t.num);
  grid.appendChild(btn);
});
[2,3,4].forEach(n=>{const z=document.getElementById('zone'+n);if(z)z.addEventListener('click',()=>selectTerrain(n));});

function checkAvailability(){
  const terrain=document.getElementById('bookingTerrain').value;
  const heure=document.getElementById('bookingHeure').value;
  const unavailEl=document.getElementById('hourUnavail');
  const heureEl=document.getElementById('bookingHeure');
  unavailEl.classList.remove('show');heureEl.style.borderColor='';
  if(!terrain||!heure)return;
  if((bookedSlots[terrain]||[]).includes(heure)){unavailEl.classList.add('show');heureEl.style.borderColor='#FF8C42';}
}
const dateEl=document.getElementById('bookingDate');
const todayJs=new Date();todayJs.setHours(0,0,0,0);
const minStr=todayJs.toISOString().split('T')[0];
const maxDate=new Date(todayJs);maxDate.setDate(maxDate.getDate()+60);
dateEl.min=minStr;dateEl.value=minStr;dateEl.max=maxDate.toISOString().split('T')[0];
function validateDateLive(){
  const v=dateEl.value;const err=document.getElementById('errDate');
  if(!v){err.textContent='Veuillez choisir une date.';err.classList.add('show');return false;}
  const d=new Date(v+'T00:00:00');
  if(d<todayJs){err.textContent='Cette date est déjà passée.';err.classList.add('show');return false;}
  if(d>maxDate){err.textContent='Maximum 60 jours à l\'avance.';err.classList.add('show');return false;}
  err.classList.remove('show');return true;
}
function closeModal(){document.getElementById('errorModal').classList.remove('show');}
function submitBooking(){
  document.querySelectorAll('.form-error').forEach(e=>e.classList.remove('show'));
  let ok=true;
  const name=document.getElementById('bookingName').value.trim();
  const phone=document.getElementById('bookingPhone').value.trim();
  const terrain=document.getElementById('bookingTerrain').value;
  const date=document.getElementById('bookingDate').value;
  const heure=document.getElementById('bookingHeure').value;
  const joueurs=document.getElementById('bookingJoueurs').value;
  if(name.length<3){document.getElementById('errName').classList.add('show');ok=false;}
  if(!phone||phone.replace(/\D/g,'').length<8){document.getElementById('errPhone').classList.add('show');ok=false;}
  if(!validateDateLive()){ok=false;}
  if(!heure){document.getElementById('errHeure').classList.add('show');ok=false;}
  if(terrain&&heure&&(bookedSlots[terrain]||[]).includes(heure)){document.getElementById('hourUnavail').classList.add('show');ok=false;}
  if(!ok)return;
  const tl=terrain?'Terrain '+terrain:'Non précisé';
  const msg=encodeURIComponent('🎾 Demande de location — Golden Padel Club Tanger\n\nNom : '+name+'\nTél : '+phone+'\n'+tl+'\nDate : '+date+'\nHeure : '+heure+'\nDurée : 1h30\nJoueurs : '+joueurs+'\nPrix estimé : 200 MAD\n\nMerci de confirmer la disponibilité.');
  window.open('https://wa.me/212664851592?text='+msg,'_blank');
}

/* CHAT SLOTS */
function toggleSlot(slotId){
  const actions=document.getElementById(slotId+'-actions');
  const bubble=document.querySelector('#'+slotId+' .slot-bubble');
  if(!actions||actions.dataset.resolved==='true')return;
  const isOpen=actions.classList.contains('show');
  document.querySelectorAll('.slot-actions').forEach(a=>{if(a.id!==slotId+'-actions')a.classList.remove('show');});
  document.querySelectorAll('.slot-bubble').forEach(b=>b.classList.remove('expanded'));
  if(!isOpen){actions.classList.add('show');bubble.classList.add('expanded');}
  else{actions.classList.remove('show');bubble.classList.remove('expanded');}
}
const slotToListId={slot1:'list-slot1',slot2:'list-slot2',slot3:'list-slot3',slot4:'list-slot4'};
function bookSlot(e,slotId,terrain,heureDebut,heureFin){
  e.stopPropagation();
  const actions=document.getElementById(slotId+'-actions');
  actions.dataset.resolved='true';actions.classList.remove('show');
  const bubble=document.querySelector('#'+slotId+' .slot-bubble');
  bubble.classList.remove('expanded');bubble.style.cursor='default';bubble.onclick=null;
  bubble.querySelector('.slot-hint').style.display='none';
  const listEl=document.getElementById(slotToListId[slotId]);
  if(listEl){listEl.style.transition='opacity .4s';listEl.style.opacity='0';setTimeout(()=>listEl.remove(),400);}
  setTimeout(()=>{const el=document.getElementById(slotId);if(el)el.remove();},2500);
  // Message structuré avec toutes les infos
  const msg=encodeURIComponent('🎾 Réservation de créneau — Golden Padel Club Tanger\n\n✅ '+terrain+'\n🕐 Horaire : '+heureDebut+' à '+heureFin+' (1h30)\n💰 Prix : 200 MAD\n📍 Quartier Boubana, Tanger\n\nBonjour, je souhaite réserver ce créneau. Merci de confirmer la disponibilité.');
  window.open('https://wa.me/212664851592?text='+msg,'_blank');
  addChatMsg('user','Je réserve : '+terrain+' de '+heureDebut+' à '+heureFin);
  setTimeout(()=>addChatMsg('admin','✅ Parfait ! Votre demande est bien reçue. Confirmation WhatsApp sous 5 minutes !'),1200);
}
function declineSlot(e,slotId){
  e.stopPropagation();
  const actions=document.getElementById(slotId+'-actions');
  actions.dataset.resolved='true';actions.classList.remove('show');
  const bubble=document.querySelector('#'+slotId+' .slot-bubble');
  bubble.classList.remove('expanded');bubble.style.cursor='default';bubble.onclick=null;
  bubble.style.opacity='0.5';
  bubble.querySelector('.slot-bubble-detail').innerHTML+='<div><span class="slot-declined-tag">❌ Non intéressé(e)</span></div>';
  bubble.querySelector('.slot-hint').style.display='none';
}
function addChatMsg(type,text){
  const msgs=document.getElementById('chatMsgs');
  const t=new Date();
  const time=t.getHours().toString().padStart(2,'0')+':'+t.getMinutes().toString().padStart(2,'0');
  const m=document.createElement('div');
  m.className='msg '+type;
  m.innerHTML='<div class="msg-lbl">'+(type==='user'?'Vous':'Golden Padel Club')+'</div><div class="msg-bubble">'+text+'</div><div class="msg-time">'+time+'</div>';
  msgs.appendChild(m);msgs.scrollTop=msgs.scrollHeight;
}

/* CHAT INPUT — tout message est structuré et envoyé vers WhatsApp */
function sendMsg(){
  const inp=document.getElementById('chatInput');
  const txt=inp.value.trim();
  if(!txt)return;
  addChatMsg('user',txt);
  inp.value='';
  setTimeout(()=>addChatMsg('admin','💬 Message reçu ! Nous vous répondrons très rapidement sur WhatsApp.'),800);
  const msg=encodeURIComponent('💬 Message — Golden Padel Club Tanger\n\n'+txt+'\n\n📍 Golden Padel Club — Boubana, Tanger\n📞 06 64 85 15 92');
  setTimeout(()=>window.open('https://wa.me/212664851592?text='+msg,'_blank'),400);
}

