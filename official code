/* AVIS */
const avisState={2:{rating:5,saved:null},3:{rating:5,saved:null}};
function openAvisForm(n){document.getElementById('avisDisplay'+n).style.display='none';document.getElementById('avisForm'+n).style.display='block';setupStars(n);}
function cancelAvis(n){document.getElementById('avisForm'+n).style.display='none';document.getElementById('avisDisplay'+n).style.display='flex';}
function setupStars(n){
  const starsEl=document.getElementById('avisStars'+n);
  updateStarDisplay(starsEl,avisState[n].rating);
  starsEl.onmousemove=function(e){const rect=starsEl.getBoundingClientRect();updateStarDisplay(starsEl,Math.max(1,Math.ceil((e.clientX-rect.left)/(rect.width/5))));};
  starsEl.onmouseleave=function(){updateStarDisplay(starsEl,avisState[n].rating);};
  starsEl.onclick=function(e){const rect=starsEl.getBoundingClientRect();avisState[n].rating=Math.max(1,Math.ceil((e.clientX-rect.left)/(rect.width/5)));updateStarDisplay(starsEl,avisState[n].rating);};
}
function updateStarDisplay(el,count){el.textContent='★'.repeat(count)+'☆'.repeat(5-count);el.style.color='var(--gold)';}
function saveAvis(n){
  const name=(document.getElementById('avisName'+n).value.trim())||'Anonyme';
  const role=(document.getElementById('avisRole'+n).value.trim())||'Joueur';
  const text=document.getElementById('avisText'+n).value.trim();
  if(!text){alert('Veuillez écrire votre avis avant de publier.');return;}
  avisState[n].saved={name,role,text,rating:avisState[n].rating};
  renderSavedAvis(n);
}
function renderSavedAvis(n){
  const data=avisState[n].saved;
  const stars='★'.repeat(data.rating)+'☆'.repeat(5-data.rating);
  const initials=data.name.split(' ').map(w=>w[0]||'').join('').substring(0,2).toUpperCase()||'??';
  document.getElementById('avisCard'+n).innerHTML='<div class="stars">'+stars+'</div><p class="avis-text">"'+data.text+'"</p><div class="avis-author"><div class="avis-avatar">'+initials+'</div><div><div class="avis-name">'+data.name+'</div><div class="avis-role">'+data.role+'</div></div></div>';
}

/* FADE IN */
const obs=new IntersectionObserver(entries=>entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible');}),{threshold:.1});
document.querySelectorAll('.fade-in').forEach(el=>obs.observe(el));

/* NAV */
const navAs=document.querySelectorAll('nav ul a');
const secs=document.querySelectorAll('section[id]');
window.addEventListener('scroll',()=>{
  let cur='';
  secs.forEach(s=>{if(window.scrollY>=s.offsetTop-120)cur=s.id;});
  navAs.forEach(a=>{a.style.color=(a.getAttribute('href')==='#'+cur)?'#C9A84C':'';});
});
</script>
